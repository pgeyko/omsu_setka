# Server
APP_ENV=development
SERVER_PORT=8080
SERVER_READ_TIMEOUT=5s
SERVER_WRITE_TIMEOUT=5s
SERVER_PREFORK=false

# Upstream
UPSTREAM_BASE_URL=https://eservice.omsu.ru/schedule/backend
UPSTREAM_TIMEOUT=10s
UPSTREAM_RATE_LIMIT=2
UPSTREAM_USER_AGENT=omsu_setka/1.0

# Synchronization
SYNC_DICT_INTERVAL=12h
SYNC_SCHEDULE_INTERVAL=15m
SYNC_AUDIT_INTERVAL=24h
SYNC_ON_STARTUP=true

# Cache
CACHE_SCHEDULE_TTL=15m
CACHE_DICT_TTL=12h
CACHE_ACTIVE_THRESHOLD=24h

# SQLite
SQLITE_PATH=./data/mirror.db
SQLITE_WAL_MODE=true
SQLITE_BUSY_TIMEOUT=5000

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Security
# CRITICAL: Change ADMIN_KEY in production!
ADMIN_KEY=your-secret-admin-key
# CRITICAL: Don't use '*' in production. Set to your domain (e.g., https://omsu.example.com)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Rate Limiting
# Total requests per minute per IP
RATE_LIMIT_GENERAL=120
# Specialized search limit per minute per IP 
RATE_LIMIT_SEARCH=30
# Time window for limits
RATE_LIMIT_WINDOW=1m

# Frontend (Vite)
# When running in Docker, leave as /api/v1 to use Nginx proxy
VITE_API_BASE=/api/v1
