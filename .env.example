# Server
APP_ENV=development
SERVER_PORT=8080
SERVER_READ_TIMEOUT=5s
SERVER_WRITE_TIMEOUT=5s
SERVER_PREFORK=false
APP_BASE_URL=https://omsu.example.com

# Upstream
UPSTREAM_BASE_URL=https://eservice.omsu.ru/schedule/backend
UPSTREAM_TIMEOUT=10s
UPSTREAM_RATE_LIMIT=2
UPSTREAM_USER_AGENT=omsu_setka/1.0

# Synchronization
SYNC_DICT_INTERVAL=12h
SYNC_SCHEDULE_INTERVAL=15m
SYNC_AUDIT_INTERVAL=24h
SYNC_ON_STARTUP=true

# Cache
CACHE_SCHEDULE_TTL=15m
CACHE_DICT_TTL=12h
CACHE_ACTIVE_THRESHOLD=24h

# SQLite
SQLITE_PATH=./data/mirror.db

# Firebase Configuration (Required for FCM Push Notifications)
# Get these from Firebase Console > Project Settings > General
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Public VAPID Key for Web Push
# Get this from Firebase Console > Project Settings > Cloud Messaging > Web Push certificates
VITE_FIREBASE_VAPID_KEY=your_vapid_key_here

# Backend Firebase Auth (JSON string from Service Account key file)
# Example: {"type": "service_account", "project_id": "...", ...}
FIREBASE_SERVICE_ACCOUNT=
SQLITE_WAL_MODE=true
SQLITE_BUSY_TIMEOUT=5000

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Security
# CRITICAL: Change ADMIN_KEY in production!
ADMIN_KEY=your-secret-admin-key
# CRITICAL: Don't use '*' in production. Set to your domain (e.g., https://omsu.example.com)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Rate Limiting
# Total requests per minute per IP
RATE_LIMIT_GENERAL=120
# Specialized search limit per minute per IP 
RATE_LIMIT_SEARCH=30
# Time window for limits
RATE_LIMIT_WINDOW=1m

# Frontend (Vite)
# When running in Docker, leave as /api/v1 to use Nginx proxy
VITE_API_BASE=/api/v1

# Analytics (Cloudflare Web Analytics)
# Optional: Set your Cloudflare Web Analytics token to track site visits.
# Leave empty or omit if not using analytics.
VITE_CF_ANALYTICS_TOKEN=
