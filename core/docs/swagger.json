        "/search": {
            "get": {
                "description": "Prefix search with autocomplete.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Search"
                ],
                "summary": "Search groups, tutors, or auditories",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Query string (min 2 chars)",
                        "name": "q",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "string",
                        "default": "all",
